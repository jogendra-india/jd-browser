{
  "name": "jd-browser",
  "displayName": "JD Browser",
  "description": "A VS Code Activity Bar browser view for local and external web pages.",
  "version": "0.0.1",
  "publisher": "jd",
  "repository": {
    "type": "git",
    "url": "https://github.com/jogendra-india/jd-browser.git"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:myBrowser.browserView",
    "onCommand:myBrowser.open"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "myBrowser.open",
        "title": "Open Browser",
        "category": "JD Browser"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "myBrowser",
          "title": "JD Browser",
          "icon": "media/browser.svg"
        }
      ]
    },
    "views": {
      "myBrowser": [
        {
          "id": "myBrowser.browserView",
          "name": "JD Browser",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "archiver": "^7.0.1",
    "eslint": "^9.39.3"
  }
}
